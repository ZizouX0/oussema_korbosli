@startuml
skinparam dpi 150
skinparam shadowing false
skinparam DefaultFontName Arial
skinparam DefaultFontSize 13
skinparam ArrowColor #14507A
skinparam roundCorner 6
left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome
skinparam usecaseBackgroundColor #EAF3FA
skinparam usecaseBorderColor #1B6CA8
skinparam actorBorderColor #14507A
actor "Utilisateur" as USR
actor "Administrateur" as ADM
rectangle "Sprint 1 — Authentification et gestion des roles" {
  usecase "S'authentifier" as A1
  usecase "Se deconnecter" as A2
  usecase "Gerer les roles\net droits d'acces" as A3
  usecase "Securiser l'acces\n(filtre de session)" as A4
}
USR --> A1
USR --> A2
ADM --> A1
ADM --> A3
A1 ..> A4 : <<include>>
@enduml