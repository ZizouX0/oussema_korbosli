@startuml
skinparam dpi 150
skinparam shadowing false
skinparam DefaultFontName Arial
skinparam DefaultFontSize 13
skinparam ArrowColor #14507A
skinparam roundCorner 6
left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome
skinparam usecaseBackgroundColor #EAF3FA
skinparam usecaseBorderColor #1B6CA8
skinparam actorBorderColor #14507A
actor "Employe" as EMP
actor "Directeur commercial" as DIR
actor "Administrateur" as ADM
rectangle "Sprint 4 — Pointage, demandes et notifications" {
  usecase "Pointer\n(arrivee / depart)" as D1
  usecase "Saisir un pointage\nmanuel" as D2
  usecase "Soumettre une\ndemande" as D3
  usecase "Valider / refuser\nune demande" as D4
  usecase "Recevoir des\nnotifications" as D5
  usecase "Consulter le\njournal d'audit" as D6
}
EMP --> D1
ADM --> D2
DIR --> D3
ADM --> D4
DIR --> D5
ADM --> D6
D4 ..> D5 : <<include>>
@enduml